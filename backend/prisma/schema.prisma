generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CalendarEvent {
  id     Int    @id @default(autoincrement())
  title  String
  tag    String
  date   String
  time   String
  day    Int
  userId Int
  user   User   @relation(fields: [userId], references: [id], map: "CalendarEvent_userId_fkey")

  @@index([userId])
  @@map("calendarevent")
}

model CircleMessage {
  id          Int         @id @default(autoincrement())
  circleId    Int
  senderId    Int
  content     String
  createdAt   DateTime    @default(now())
  studyCircle StudyCircle @relation(fields: [circleId], references: [id], map: "CircleMessage_circleId_fkey")
  sender      User        @relation(fields: [senderId], references: [id], map: "CircleMessage_senderId_fkey")

  @@index([circleId])
  @@index([senderId])
  @@map("circlemessage")
}

model CircleSchedule {
  id          Int         @id @default(autoincrement())
  circleId    Int
  title       String
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime    @default(now())
  studyCircle StudyCircle @relation(fields: [circleId], references: [id], map: "CircleSchedule_circleId_fkey")

  @@index([circleId])
  @@map("circleschedule")
}

model DailyActivity {
  id     Int      @id @default(autoincrement())
  date   DateTime
  count  Int      @default(0)
  userId Int
  user   User     @relation(fields: [userId], references: [id], map: "DailyActivity_userId_fkey")

  @@unique([date, userId])
  @@index([userId])
  @@map("dailyactivity")
}

model Goal {
  id                Int          @id @default(autoincrement())
  title             String
  type              String
  progress          Int          @default(0)
  userId            Int
  createdAt         DateTime     @default(now())
  studyCircleId     Int?
  completedAt       DateTime?
  completionCounted Boolean      @default(false)
  isImportant       Boolean      @default(false)
  studyCircle       StudyCircle? @relation(fields: [studyCircleId], references: [id], map: "Goal_studyCircleId_fkey")
  user              User         @relation(fields: [userId], references: [id], map: "Goal_userId_fkey")
  tasks             Task[]

  @@index([completedAt])
  @@index([studyCircleId])
  @@index([userId])
  @@map("goal")
}

model GoalStats {
  id                     String    @id @default("global")
  lifetimeGoalsCompleted Int       @default(0)
  lifetimeGoalsMissed    Int       @default(0)
  lastRunDate            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@map("goalstats")
}

model Resource {
  id            Int          @id @default(autoincrement())
  title         String
  url           String?
  description   String?
  uploadedAt    DateTime     @default(now())
  uploaderId    Int
  studyCircleId Int?
  fileType      String?
  fileUrl       String?
  studyCircle   StudyCircle? @relation(fields: [studyCircleId], references: [id], map: "Resource_studyCircleId_fkey")
  uploader      User         @relation(fields: [uploaderId], references: [id], map: "Resource_uploaderId_fkey")

  @@index([studyCircleId])
  @@index([uploaderId])
  @@map("resource")
}

model SessionParticipant {
  id           Int          @id @default(autoincrement())
  sessionId    Int
  userId       Int
  joinedAt     DateTime     @default(now())
  lastPing     DateTime     @default(now())
  status       String       @default("ACTIVE")
  studySession StudySession @relation(fields: [sessionId], references: [id], map: "SessionParticipant_sessionId_fkey")
  user         User         @relation(fields: [userId], references: [id], map: "SessionParticipant_userId_fkey2")

  @@unique([sessionId, userId])
  @@index([userId])
  @@map("sessionparticipant")
}

model StudyCircle {
  id              Int                     @id @default(autoincrement())
  name            String
  description     String?
  inviteCode      String                  @unique
  createdAt       DateTime                @default(now())
  circleMessages  CircleMessage[]
  circleSchedules CircleSchedule[]
  goals           Goal[]
  resources       Resource[]
  members         StudyCircleMembership[]
  studySessions   StudySession[]

  @@map("studycircle")
}

model StudyCircleMembership {
  id            Int         @id @default(autoincrement())
  joinedAt      DateTime    @default(now())
  userId        Int
  studyCircleId Int
  studyCircle   StudyCircle @relation(fields: [studyCircleId], references: [id], map: "StudyCircleMembership_studyCircleId_fkey")
  user          User        @relation(fields: [userId], references: [id], map: "StudyCircleMembership_userId_fkey2")

  @@unique([userId, studyCircleId])
  @@index([studyCircleId])
  @@map("studycirclemembership")
}

model StudySession {
  id           Int                  @id @default(autoincrement())
  circleId     Int
  startTime    DateTime             @default(now())
  duration     Int                  @default(25)
  status       String               @default("ACTIVE")
  participants SessionParticipant[]
  studyCircle  StudyCircle          @relation(fields: [circleId], references: [id], map: "StudySession_circleId_fkey")

  @@index([circleId])
  @@map("studysession")
}

model Task {
  id                Int      @id @default(autoincrement())
  title             String
  completed         Boolean  @default(false)
  focusMinutes      Int?
  goalId            Int
  userId            Int
  createdAt         DateTime @default(now())
  completedAt       DateTime?
  completionCounted Boolean  @default(false)
  goal              Goal     @relation(fields: [goalId], references: [id], map: "Task_goalId_fkey")
  user              User     @relation(fields: [userId], references: [id], map: "Task_userId_fkey2")

  @@index([goalId])
  @@index([userId])
  @@index([completedAt])
  @@map("task")
}

model User {
  id                         Int                     @id @default(autoincrement())
  name                       String
  email                      String                  @unique
  password                   String
  createdAt                  DateTime                @default(now())
  refreshToken               String?
  role                       user_role               @default(USER)
  passwordResetExpires       DateTime?
  passwordResetToken         String?
  avatar                     String?
  bio                        String?
  notifs                     Json?
  xp                         Int                     @default(0)
  level                      Int                     @default(1)
  deletedCompletedGoalsCount Int                     @default(0)
  deletedCompletedGoalsDate  DateTime?
  lifetimeGoalsCompleted     Int                     @default(0)
  lifetimeGoalsMissed        Int                     @default(0)
  lifetimeTasksCompleted     Int                     @default(0)
  lifetimeTasksCreated       Int                     @default(0)
  calendarEvents             CalendarEvent[]
  circleMessages             CircleMessage[]
  dailyActivities            DailyActivity[]
  goals                      Goal[]
  notes                      Note[]
  resources                  Resource[]
  sessionParticipants        SessionParticipant[]
  memberships                StudyCircleMembership[]
  userStudySessions          UserStudySession[]
  tasks                      Task[]
  user_achievements          user_achievements[]

  @@map("user")
}

model UserStudySession {
  id       Int      @id @default(autoincrement())
  userId   Int
  subject  String
  duration Int
  date     DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], map: "UserStudySession_userId_fkey")

  @@index([date])
  @@index([userId])
  @@map("studysession_log")
}

model Note {
  id        Int      @id @default(autoincrement())
  text      String
  tag       String
  color     String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int
  user      User     @relation(fields: [userId], references: [id], map: "Note_userId_fkey2")

  @@index([userId])
  @@map("note")
}

model achievement_definitions {
  id                Int                 @id @default(autoincrement())
  key               String              @unique
  name              String
  description       String
  category          String
  threshold         Int
  points            Int
  level             Int                 @default(1)
  is_hidden         Boolean             @default(false)
  user_achievements user_achievements[]
}

model user_achievements {
  id                      Int                     @id @default(autoincrement())
  user_id                 Int
  achievement_id          Int
  unlocked_at             DateTime                @default(now())
  progress_value          Int                     @default(0)
  level_unlocked          Int                     @default(1)
  achievement_definitions achievement_definitions @relation(fields: [achievement_id], references: [id])
  user                    User                    @relation(fields: [user_id], references: [id])

  @@unique([user_id, achievement_id])
  @@index([achievement_id])
  @@index([user_id])
}

enum user_role {
  USER
  ADMIN
}
