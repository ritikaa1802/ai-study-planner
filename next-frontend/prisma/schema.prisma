generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CalendarEvent {
  id     Int    @id @default(autoincrement())
  title  String
  tag    String
  date   String
  time   String
  day    Int
  userId Int
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("calendarevent")
}

model CircleMessage {
  id          Int         @id @default(autoincrement())
  circleId    Int
  senderId    Int
  content     String
  createdAt   DateTime    @default(now())
  studyCircle StudyCircle @relation(fields: [circleId], references: [id])
  sender      User        @relation(fields: [senderId], references: [id])

  @@index([circleId])
  @@index([senderId])
  @@map("circlemessage")
}

model CircleSchedule {
  id          Int         @id @default(autoincrement())
  circleId    Int
  title       String
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime    @default(now())
  studyCircle StudyCircle @relation(fields: [circleId], references: [id])

  @@index([circleId])
  @@map("circleschedule")
}

model DailyActivity {
  id     Int      @id @default(autoincrement())
  date   DateTime
  count  Int      @default(0)
  userId Int
  user   User     @relation(fields: [userId], references: [id])

  @@unique([date, userId])
  @@index([userId])
  @@map("dailyactivity")
}

model Goal {
  id            Int          @id @default(autoincrement())
  title         String
  type          String
  progress      Int          @default(0)
  isImportant   Boolean      @default(false)
  completionCounted Boolean  @default(false)
  completedAt   DateTime?
  userId        Int
  createdAt     DateTime     @default(now())
  studyCircleId Int?
  studyCircle   StudyCircle? @relation(fields: [studyCircleId], references: [id])
  user          User         @relation(fields: [userId], references: [id])
  tasks         Task[]

  @@index([completedAt])
  @@index([studyCircleId])
  @@index([userId])
  @@map("goal")
}

model GoalStats {
  id                     String   @id @default("global")
  lifetimeGoalsCompleted Int      @default(0)
  lifetimeGoalsMissed    Int      @default(0)
  lastRunDate            DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("goalstats")
}

model Resource {
  id            Int          @id @default(autoincrement())
  title         String
  url           String?
  description   String?
  uploadedAt    DateTime     @default(now())
  uploaderId    Int
  studyCircleId Int?
  fileType      String?
  fileUrl       String?
  studyCircle   StudyCircle? @relation(fields: [studyCircleId], references: [id])
  uploader      User         @relation(fields: [uploaderId], references: [id])

  @@index([studyCircleId])
  @@index([uploaderId])
  @@map("resource")
}

model SessionParticipant {
  id           Int          @id @default(autoincrement())
  sessionId    Int
  userId       Int
  joinedAt     DateTime     @default(now())
  lastPing     DateTime     @default(now())
  status       String       @default("ACTIVE")
  studySession StudySession @relation(fields: [sessionId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([userId])
  @@map("sessionparticipant")
}

model StudyCircle {
  id                    Int                     @id @default(autoincrement())
  name                  String
  description           String?
  inviteCode            String                  @unique
  createdAt             DateTime                @default(now())
  circleMessages        CircleMessage[]
  circleSchedules       CircleSchedule[]
  goals                 Goal[]
  resources             Resource[]
  members               StudyCircleMembership[]
  studySessions         StudySession[]

  @@map("studycircle")
}

model StudyCircleMembership {
  id            Int         @id @default(autoincrement())
  joinedAt      DateTime    @default(now())
  userId        Int
  studyCircleId Int
  studyCircle   StudyCircle @relation(fields: [studyCircleId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@unique([userId, studyCircleId])
  @@index([studyCircleId])
  @@map("studycirclemembership")
}

model StudySession {
  id           Int                  @id @default(autoincrement())
  circleId     Int
  startTime    DateTime             @default(now())
  duration     Int                  @default(25)
  status       String               @default("ACTIVE")
  participants SessionParticipant[]
  studyCircle  StudyCircle          @relation(fields: [circleId], references: [id])

  @@index([circleId])
  @@map("studysession")
}

model Task {
  id                Int      @id @default(autoincrement())
  title             String
  completed         Boolean  @default(false)
  completionCounted Boolean  @default(false)
  focusMinutes      Int?
  goalId            Int
  userId            Int
  createdAt         DateTime @default(now())
  completedAt       DateTime?
  goal              Goal     @relation(fields: [goalId], references: [id])
  user              User     @relation(fields: [userId], references: [id])

  @@index([goalId])
  @@index([userId])
  @@index([completedAt])
  @@map("task")
}

model User {
  id                    Int                     @id @default(autoincrement())
  name                  String
  email                 String                  @unique
  password              String
  lifetimeTasksCreated  Int                     @default(0)
  lifetimeTasksCompleted Int                    @default(0)
  lifetimeGoalsCompleted Int                    @default(0)
  lifetimeGoalsMissed   Int                     @default(0)
  deletedCompletedGoalsCount Int                @default(0)
  deletedCompletedGoalsDate DateTime?
  createdAt             DateTime                @default(now())
  refreshToken          String?
  role                  user_role               @default(USER)
  passwordResetExpires  DateTime?
  passwordResetToken    String?
  avatar                String?
  bio                   String?
  notifs                Json?
  xp                    Int                     @default(0)
  level                 Int                     @default(1)
  calendarEvents        CalendarEvent[]
  circleMessages        CircleMessage[]
  dailyActivities       DailyActivity[]
  goals                 Goal[]
  resources             Resource[]
  sessionParticipants   SessionParticipant[]
  userStudySessions     UserStudySession[]
  memberships           StudyCircleMembership[]
  tasks                 Task[]
  achievements          UserAchievement[]
  notes                 Note[]

  @@map("user")
}

model AchievementDefinition {
  id              Int               @id @default(autoincrement())
  key             String            @unique
  name            String
  description     String
  category        String
  threshold       Int
  points          Int
  level           Int               @default(1)
  isHidden        Boolean           @default(false) @map("is_hidden")
  userAchievements UserAchievement[]

  @@map("achievement_definitions")
}

model UserAchievement {
  id             Int                   @id @default(autoincrement())
  userId         Int                   @map("user_id")
  achievementId  Int                   @map("achievement_id")
  unlockedAt     DateTime              @default(now()) @map("unlocked_at")
  progressValue  Int                   @default(0) @map("progress_value")
  levelUnlocked  Int                   @default(1) @map("level_unlocked")
  user           User                  @relation(fields: [userId], references: [id])
  achievement    AchievementDefinition @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@map("user_achievements")
}

model UserStudySession {
  id       Int      @id @default(autoincrement())
  userId   Int
  subject  String
  duration Int
  date     DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([date])
  @@map("studysession_log")
}

enum user_role {
  USER
  ADMIN
}

model Note {
  id        Int      @id @default(autoincrement())
  text      String
  tag       String
  color     String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("note")
}
