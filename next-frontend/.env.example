# Database used by Prisma in Next API routes
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Auth secrets (must match existing backend values if sharing tokens)
JWT_SECRET="your-jwt-secret"
JWT_REFRESH_SECRET="your-refresh-secret"

# Optional: fallback backend base URL for APIs not yet migrated to Next routes
# Example: https://your-backend-domain.com
BACKEND_API_URL=""

# Optional frontend API override. Leave empty to use same-origin /api on Vercel.
NEXT_PUBLIC_API_URL=""

# AI Planner (required for real plan generation)
GROQ_API_KEY=""

# Optional model override
GROQ_MODEL="llama-3.3-70b-versatile"
